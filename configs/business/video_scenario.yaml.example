# ================================================================
# VIDEO SCENARIO EXAMPLE — Copy and rename to use
# ================================================================
# Copy file này, đổi tên và điền nội dung theo kịch bản video của bạn
# Rename: video_scenario.yaml.example → video_scenario.yaml
# ================================================================

# ------------------------------------------------------------
# VOICES — Voice catalog with multi-provider support
# ------------------------------------------------------------
voices:
  - id: "female_teacher"
    name: "Cô giáo"
    gender: "female"
    providers:
      - provider: "edge"
        model: "vi-VN-HoaiMyNeural"
        speed: 1.0
      - provider: "openai"
        model: "tts-1"
        voice: "alloy"
        speed: 1.0

  - id: "male_student"
    name: "Học sinh nam"
    gender: "male"
    providers:
      - provider: "edge"
        model: "vi-VN-NamMinhNeural"
        speed: 1.0

# ------------------------------------------------------------
# CHARACTERS — Virtual avatar speakers
# ------------------------------------------------------------
characters:
  - name: "GiaoVien"
    voice_id: "female_teacher"

  - name: "TomCua"
    voice_id: "male_student"

# ------------------------------------------------------------
# SCENES — Video script broken into scenes
# ------------------------------------------------------------
scenes:
  # Single character scene
  - id: 1
    tts: "Hook - câu mở đầu hấp dẫn để giữ chú ý người xem"
    video_prompt: "A friendly female teacher in modern classroom, warm smile, enthusiastic expression"
    characters:
      - name: "GiaoVien"
    background: "office"

  # Multi-character scene (explicit tts per character)
  - id: 2
    video_prompt: "Female teacher and male student having an engaging conversation in modern classroom"
    characters:
      - name: "GiaoVien"
        tts: "Bây giờ tôi sẽ chia sẻ điều gì đó rất thú vị."
        speed: 1.0
      - name: "TomCua"
        tts: "Ôi tuyệt quá! Cho tôi xin câu hỏi đầu tiên."
        speed: 1.1
    background: "classroom"

# ------------------------------------------------------------
# VIDEO — Basic video settings
# ------------------------------------------------------------
video:
  aspect_ratio: "9:16"      # 9:16 (TikTok/Reels) | 16:9 (YouTube) | 1:1 (Square)
  resolution: "480p"         # 480p | 720p | 1080p

# ------------------------------------------------------------
# SUBTITLE — Karaoke-style subtitles
# ------------------------------------------------------------
subtitle:
  font_size: 60

# ------------------------------------------------------------
# BACKGROUND MUSIC — Ambient music overlay
# ------------------------------------------------------------
background_music:
  enable: true
  file: "random"             # "random" = randomize from music folder
  volume: 0.15               # 0.0 - 1.0
  fade_duration: 2            # seconds

# ------------------------------------------------------------
# WATERMARK — On-screen watermark
# ------------------------------------------------------------
watermark:
  enable: true
  text: "@YourChannelName"
  font_size: 30
  opacity: 0.15              # 0.0 - 1.0
  motion: "bounce"           # bounce | fade | slide | static
  bounce_speed: 80
  bounce_padding: 20
  velocity_x: 1.2
  velocity_y: 0.8
  margin: 8

# ------------------------------------------------------------
# MODELS — Provider selection
# ------------------------------------------------------------
models:
  tts: "edge"
  image: "minimax"
  video: "kieai"

tts:
  max_duration: 15.0
  min_duration: 5.0
  words_per_second: 2.5

# ------------------------------------------------------------
# LIPSYNC — Video generation from image + audio
# ------------------------------------------------------------
lipsync:
  provider: "kieai"           # kieai | wavespeed
  resolution: "480p"          # 480p | 720p | 1080p
  max_wait: 300               # seconds to wait for job completion

# ------------------------------------------------------------
# LLM — Language model for script generation
# ------------------------------------------------------------
llm:
  provider: "minimax"   # minimax | openai | anthropic
  model: "MiniMax-M2.7"
  max_tokens: 1536

# ------------------------------------------------------------
# SOCIAL — Page/Channel configuration for auto-posting
# ------------------------------------------------------------
social:
  facebook:
    page_name: "YourPageName"
    auto_publish: false
  tiktok:
    account_name: "@YourTikTokHandle"
    auto_publish: false
